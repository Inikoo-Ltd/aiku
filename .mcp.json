{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "postgres": {
            "command": "sh",
            "args": [
                "-c",
                "set -a && . /home/aiku/aiku/.env && set +a && npx -y @modelcontextprotocol/server-postgres \"postgresql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:5432/${DB_DATABASE}\""
            ]
        }
    }
}