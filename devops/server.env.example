# Secrets consumed by setup-server.sh to render devops/ configs.
# Copy to devops/server.env (gitignored) and fill in real values.

# HAProxy stats page auth (bound on :8880) — used in haproxy.cfg
HAPROXY_STATS_USER=inikoo
HAPROXY_STATS_PASSWORD=change-me

# Varnish backend hosts — used in varnish/default.vcl.
# Production: the two app servers (boro=10.0.0.3, helio=10.0.0.2).
# Single-box / staging: point both at itself, e.g. 127.0.0.1.
VARNISH_HOST_BORO=10.0.0.3
VARNISH_HOST_HELIO=10.0.0.2

# Install the Laravel scheduler crontab on THIS host? Exactly one host in the
# fleet must set this to 1 — two schedulers double every task. Default off.
INSTALL_SCHEDULER=0
